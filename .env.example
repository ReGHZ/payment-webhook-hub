# App
NODE_ENV=development

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3005
LOG_LEVEL=info

# Provider Tokens (referenced by envKey in providers.json)
XENDIT_CALLBACK_TOKEN=your-xendit-callback-token

# Admin
ADMIN_BEARER_TOKEN=your-admin-token
ADMIN_USER=admin

# Config
TARGETS_FILE_PATH=./config/targets.json
PROVIDERS_FILE_PATH=./config/providers.json

# Docker Network
EXTERNAL_NETWORK=payment-webhook-hub-network

# Docker runtime UID/GID — untuk docker-compose (bukan di-load ke dalam container).
# Cek UID host kamu pakai `id -u` / `id -g`. Default 1000 match Linux install paling umum.
# Kalau host VPS UID lain (mis. 1001, 1002), override di sini biar file config/ hasil save
# admin UI bisa di-edit manual tanpa sudo.
PUID=1000
PGID=1000

# Alerting
DISCORD_WEBHOOK_URL=
