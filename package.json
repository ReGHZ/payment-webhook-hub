{
  "name": "payment-webhook-hub",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --exec \"tsx src/index.ts\"",
    "dev:worker": "nodemon --watch src --ext ts --exec \"tsx src/worker.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "bullmq": "^5.73.1",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
